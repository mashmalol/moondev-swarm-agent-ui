# ============================================
# 🌙 Moon Dev's Swarm Agent - Environment Variables
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORGANIZATION=org-xxxxxxxxxxxxxxxx

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Configuration
GOOGLE_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek Configuration
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter Configuration
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# XAI Configuration
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama Configuration (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Application Settings
DEBUG=False
LOG_LEVEL=INFO
SAVE_RESULTS=True
RESULTS_DIR=./data/swarm_agent
MAX_FILE_SIZE_MB=10
ENABLE_CACHING=True
CACHE_TTL_SECONDS=3600

# Web UI Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_BROWSER_GATHER_USAGE_STATS=False
STREAMLIT_SERVER_ENABLE_CORS=False

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ENABLE_RATE_LIMITING=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Database (optional)
DATABASE_URL=postgresql://swarmuser:swarmpass@localhost:5432/swarmdb
REDIS_URL=redis://localhost:6379/0